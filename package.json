	"type": "module",
	"scripts": {
		"start": "node --enable-source-maps build/index.js",
		"dev": "vite dev",
		"build": "vite build && node fixSourcemaps.cjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
